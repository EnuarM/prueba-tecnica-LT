# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- MongoDB ---
# Formato: mongodb://usuario:password@host:puerto/base-de-datos
MONGODB_URI=mongodb://root:secret@localhost:27017/banking_platform?authSource=admin

# --- JWT ---
# Cambiar por un string aleatorio largo en producción (mínimo 32 caracteres)
JWT_SECRET=cambiar-por-un-secret-seguro-en-produccion
JWT_EXPIRATION=1h

# --- Usuarios mock para autenticación (solo desarrollo) ---
# Formato: email:password:rol (separados por coma para múltiples usuarios)
AUTH_ADMIN_EMAIL=admin@banking.com
AUTH_ADMIN_PASSWORD=Admin1234!
AUTH_OPERATOR_EMAIL=operator@banking.com
AUTH_OPERATOR_PASSWORD=Operator1234!
AUTH_CLIENT_EMAIL=client@banking.com
AUTH_CLIENT_PASSWORD=Client1234!

# --- Integración Mulesoft / Core Bancario ---
MULESOFT_BASE_URL=http://localhost:8081
MULESOFT_CLIENT_ID=your-client-id
MULESOFT_CLIENT_SECRET=your-client-secret
MULESOFT_TIMEOUT_MS=5000

# --- CORS ---
# Orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
